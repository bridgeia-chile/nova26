ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# API Server
