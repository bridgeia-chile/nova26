<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>nova26 | Dashboard de Inteligencia Artificial</title>
    <meta name="description" content="Dashboard avanzado para gestión de agentes de inteligencia artificial con Nova26">
    <meta name="keywords" content="AI, inteligencia artificial, dashboard, agentes, Nova26, automatización">
    <meta name="author" content="NovaGravity Team">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="nova26 | Dashboard de Inteligencia Artificial">
    <meta property="og:description" content="Dashboard avanzado para gestión de agentes de inteligencia artificial con Nova26">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://novagravity.ai">
    <meta property="og:image" content="https://novagravity.ai/images/og-image.jpg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="nova26 | Dashboard de Inteligencia Artificial">
    <meta name="twitter:description" content="Dashboard avanzado para gestión de agentes de inteligencia artificial con Nova26">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="canonical" href="https://novagravity.ai">
    <link rel="preload" href="style.css" as="style">
    <link rel="preload" href="app.js" as="script">
    <link rel="stylesheet" href="style.min.css">
<link rel="preload" href="animations.js" as="script">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'GA_MEASUREMENT_ID');
    </script>
</head>
<body>
    <div class="background-blobs">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <main class="dashboard-container">
        <!-- Sidebar / Navigation -->
        <aside class="glass-nav" aria-label="Menú de navegación principal">
            <div class="logo-area">
                <div class="nova-logo" aria-hidden="true"></div>
                <h1>nova26 <span id="update-badge" class="badge hidden" aria-live="polite">Actualización Disponible</span></h1>
            </div>
            <nav aria-label="Navegación principal">
                <div id="nav-resumen" class="nav-item active" role="button" tabindex="0" aria-label="Ver resumen" aria-current="page">🚀 Resumen</div>
                <div id="nav-memoria" class="nav-item" role="button" tabindex="0" aria-label="Ver memoria">🧠 Memoria</div>
                <div id="nav-herramientas" class="nav-item" role="button" tabindex="0" aria-label="Ver herramientas">🛠 Herramientas</div>
                <div id="nav-ajustes" class="nav-item" role="button" tabindex="0" aria-label="Ver ajustes">⚙️ Ajustes</div>
            </nav>
            <div class="system-status" aria-live="polite">
                <div class="status-indicator online" aria-hidden="true"></div>
                <span>Agente Online</span>
            </div>
        </aside>

        <!-- Main Content -->
        <section class="content-area" aria-label="Contenido principal">
            <header class="top-bar" role="banner">
                <div class="search-glass">
                    <input type="text" placeholder="Buscar en la memoria..." aria-label="Buscar en la memoria">
                </div>
                <div class="user-profile" aria-label="Perfil de usuario">
                    <span>Admin</span>
                    <div class="avatar" aria-hidden="true"></div>
                </div>
            </header>

            <div class="global-info-bar">
                <div class="info-pill" id="btn-tunnel" style="cursor: pointer; background: rgba(0,255,136,0.1); border: 1px solid rgba(0,255,136,0.3);">🌐 Red Nova P2P</div>
                <div class="info-pill" id="btn-ha-config" style="cursor: pointer; background: rgba(3,169,244,0.1); border: 1px solid rgba(3,169,244,0.3);">🏠 Home Assistant</div>
                <div class="info-pill">🗄️ DB: <span id="db-size">0 KB</span></div>
                <div class="info-pill">👥 Sesiones: <span id="active-sessions">0</span></div>
                <div class="info-pill">🎨 Stitch: <span id="stitch-usage">0</span>/350</div>
                <div class="info-pill">🛡️ Seguridad: <span id="security-status">OK</span></div>
                <div class="info-pill">💻 CPU: <span id="sys-cpu">0%</span></div>
                <div class="info-pill">🧠 RAM: <span id="sys-ram">0 MB</span></div>
                <div class="info-pill">🎮 VRAM: <span id="sys-vram">0 GB</span></div>
            </div>

            <div id="agents-grid" class="agents-grid" role="grid" aria-label="Cuadrícula de agentes">
                <!-- Agent cards will be injected here by app.js -->
                <div class="glass-card agent-card" role="gridcell">
                    <div class="card-header">
                        <span class="agent-name">Cargando agentes...</span>
                    </div>
                </div>
            </div>

            <div class="main-split">
                <div class="glass-card chat-container" aria-label="Contenedor de chat">
                    <div class="chat-header" role="heading" aria-level="2">Interacción Directa</div>
                    <div class="chat-messages" id="chat-messages" role="log" aria-live="polite">
                        <div class="msg bot" role="status">Hola. Soy Nova. ¿En qué puedo ayudarte hoy?</div>
                    </div>
                    <div class="chat-input-area">
                        <input type="text" id="chat-input" placeholder="Escribe un comando o pregunta..." aria-label="Entrada de mensaje de chat">
                        <button id="send-btn" aria-label="Enviar mensaje">Enviar</button>
                    </div>
                </div>
                
                <div class="glass-card activity-log" aria-label="Registro de actividad">
                    <div class="chat-header" role="heading" aria-level="2">Log de Actividad</div>
                    <ul id="activity-list" role="list">
                        <li role="listitem">[SYSTEM] Boot sequence complete.</li>
                        <li role="listitem">[TELEGRAM] Voice message received.</li>
                        <li role="listitem">[CORE] Tool ScriptExecutor activated.</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Settings Content -->
        <section id="settings-view" class="content-area hidden">
            <header class="top-bar">
                <h2>⚙️ Ajustes del Sistema</h2>
            </header>
            
            <div class="glass-card settings-card">
                <div class="settings-header">
                    <h3>🤖 Gestión de Modelos Inteligentes</h3>
                    <p>Configura qué modelos están disponibles para tus agentes y su comportamiento base.</p>
                </div>
                
                <div id="models-settings-grid" class="models-settings-grid">
                    <!-- Model cards will be injected here by app.js -->
                    <p style="padding: 20px; color: var(--text-dim);">Cargando modelos...</p>
                </div>
            </div>
        </section>
    </main>

    <!-- Agent Chat Modal -->
    <div id="agent-chat-modal" class="modal-overlay hidden" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="glass-card modal-content">
            <div class="modal-header">
                <h2 id="modal-agent-name">Agente</h2>
                <button id="close-modal-btn" class="close-btn" aria-label="Cerrar modal">&times;</button>
            </div>
            <div class="chat-messages" id="modal-chat-messages" role="log" aria-live="polite">
                <div class="msg bot" role="status">Conexión directa establecida. ¿Qué necesitas?</div>
            </div>
            <div class="chat-input-area">
                <input type="text" id="modal-chat-input" placeholder="Comando para este agente..." aria-label="Entrada de mensaje para agente">
                <button id="modal-send-btn" aria-label="Enviar mensaje al agente">Enviar</button>
            </div>
        </div>
    </div>

    <!-- Tunnel Modal -->
    <div id="tunnel-modal" class="modal-overlay hidden">
        <div class="glass-card modal-content" style="max-width: 600px;">
            <div class="modal-header">
                <h2>🌐 Red Nova (Túnel P2P)</h2>
                <button id="close-tunnel-btn" class="close-btn">&times;</button>
            </div>
            
            <div style="margin-bottom: 20px;">
                <h3>Conectar a Host</h3>
                <div class="chat-input-area" style="padding: 0; background: none; border: none; margin-top: 10px;">
                    <input type="text" id="tunnel-host-input" placeholder="ws://IP_DEL_HOST:8090/ws/tunnel" style="margin-right: 10px;">
                    <button id="tunnel-connect-btn">Conectar</button>
                </div>
                <p style="font-size: 0.8rem; color: #aaa; margin-top: 5px;">Host actual: <span id="current-target-host" style="color:#00ff88;">Ninguno</span></p>
            </div>

            <div style="margin-bottom: 20px;">
                <h3>Nodos Conectados</h3>
                <ul id="active-tunnels-list" style="list-style:none; padding:0; font-size: 0.9rem; margin-top: 10px;">
                    <li style="color: #aaa;">Ninguno</li>
                </ul>
            </div>

            <div>
                <h3>Solicitudes Pendientes</h3>
                <ul id="pending-tunnels-list" style="list-style:none; padding:0; font-size: 0.9rem; margin-top: 10px;">
                    <li style="color: #aaa;">Ninguna</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Home Assistant Modal -->
    <div id="ha-modal" class="modal-overlay hidden">
        <div class="glass-card modal-content" style="max-width: 600px;">
            <div class="modal-header">
                <h2>🏠 Integración Home Assistant</h2>
                <button id="close-ha-btn" class="close-btn">&times;</button>
            </div>
            
            <div style="margin-bottom: 20px;">
                <p style="font-size: 0.9rem; color: #ccc; margin-bottom: 15px;">
                    Controla tu hogar inteligente de forma nativa proporcionando la URL y el 
                    Token de Larga Duración (Long-Lived Access Token) de tu perfil de Home Assistant.
                </p>
                <div style="margin-bottom: 10px;">
                    <label style="display:block; margin-bottom: 5px; font-size: 0.85rem; color: #aaa;">URL de Home Assistant</label>
                    <input type="text" id="ha-url-input" placeholder="http://192.168.1.100:8123" style="width: 100%; padding: 10px; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 5px;">
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="display:block; margin-bottom: 5px; font-size: 0.85rem; color: #aaa;">Long-Lived Access Token</label>
                    <input type="password" id="ha-token-input" placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6..." style="width: 100%; padding: 10px; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 5px;">
                </div>
                
                <button id="ha-save-btn" style="background: rgba(3,169,244,0.3); border: 1px solid rgba(3,169,244,0.5); color: white; padding: 10px 20px; border-radius: 5px; cursor: pointer; transition: all 0.3s; width: 100%;">
                    Guardar Configuración
                </button>
                <p id="ha-status-msg" style="font-size: 0.8rem; color: #00ff88; margin-top: 10px; text-align: center; height: 15px;"></p>
            </div>
        </div>
    </div>

    <style>
        .badge {
            background: #ff4757;
            color: white;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            margin-left: 10px;
            vertical-align: middle;
            font-weight: bold;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { opacity: 0.7; }
            50% { opacity: 1; }
            100% { opacity: 0.7; }
        }
        .hidden { display: none !important; }
    </style>
    <script src="app.min.js"></script>
</body>
</html>
